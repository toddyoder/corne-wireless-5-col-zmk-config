#define ZMK_POINTING_DEFAULT_MOVE_VAL 1500  // default mouse speed: 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 20    // default scroll speed: 10

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>            /* bluetooth */
#include <dt-bindings/zmk/pointing.h>      /* mouse emulation */

// Corne 5-column layout key indices
#define KEYS_L 0 1 2 3 4 10 11 12 13 14 20 21 22 23 24 30 31 32 // Left-hand keys + Left thumbs
#define KEYS_R 5 6 7 8 9 15 16 17 18 19 25 26 27 28 29 33 34 35 // Right-hand keys + Right thumbs
#define THUMBS 30 31 32 33 34 35                                // Thumbs

#define AS(keycode) &as LS(keycode) keycode

/ {
    chosen {
        zmk,physical-layout = &foostan_corne_5col_layout;
    };

    macros {
        pos_console: pos_console {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(K)>, <&kp F>;
        };
    };

    behaviors {
        ss: space-shift {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <220>;
            bindings = <&kp>, <&kp>;
            hold-trigger-on-release;
        };
        space_morph: space_morph {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&ss RSHIFT SPACE>, <&kp SPACE>;
            mods = <MOD_LSFT>;
        };
        lft: left-thumbs {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            bindings = <&mo>, <&kp>;
            hold-trigger-on-release;
        };
        hml: home-row-mod-left {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            require-prior-idle-ms = <75>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            bindings = <&kp>, <&kp>;
            hold-trigger-key-positions = <KEYS_R THUMBS>;
            hold-trigger-on-release;
        };
        hmr: home-row-mod-right {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            require-prior-idle-ms = <75>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            bindings = <&kp>, <&kp>;
            hold-trigger-key-positions = <KEYS_L THUMBS>;
            hold-trigger-on-release;
        };
        hm: home-row-mod {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            require-prior-idle-ms = <75>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            bindings = <&kp>, <&kp>;
            hold-trigger-on-release;
        };
        hms: home-row-mod-shift {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            require-prior-idle-ms = <50>;
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            bindings = <&kp>, <&kp>;
            hold-trigger-on-release;
        };
        mt_tap: mod_tap_tap_preffered {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            quick-tap-ms = <175>;
            bindings = <&kp>, <&kp>;
        };
        tildasgn: tilde-assign {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp TILDE>, <&kp LA(MINUS)>;
            mods = <(MOD_LSFT)>;
        };
    };

keymap {
    compatible = "zmk,keymap";
    default_layer {
// -----------------------------------------------------------------------------------------
// |  .> |  ,< |  P  |  Y  |  F  |     |  G  |  C   |  R   |  L  | ;: |
// |  A  |  O  |  E  |  U  |  I  |     |  D  |  H   |  T   |  N  | S  | 
// |  '" |  Q  |  J  |  K  |  X  |     |  B  |  M   |  W   |  V  | Z  |
//             |  L3 |  L2 | ENT |     | SPC | BSPC |  DEL |
        display-name = "Base";
        bindings = <
   &kp DOT        &kp COMMA      &kp P         &kp Y        &kp F         &kp G          &kp C         &kp R          &kp L           &kp SEMI
   &hms LSHIFT A  &hml LCTRL O   &hml LALT E   &hml LGUI U  &kp I         &kp D          &hmr RGUI H   &hmr RALT T    &hmr RCTRL N    &hms RSHIFT S
   &kp SQT        &kp Q          &kp J         &kp K        &kp X         &kp B          &kp M         &kp W          &kp V           &kp Z
                                 &lft 3 DEL    &lft 2 BSPC  &lft 1 RET    &space_morph   &kp BSPC      &kp DEL
        >;
    };

    number_layer1 {
// -----------------------------------------------------------------------------------------
// | ESC | lLFT | UP   | Pdsk | Ndsk |      |    |  7&  |  8* | 9( | /? |
// | TAB | LFT  | DOWN | RGT  | lRGT |      | =+ |  4$  |  5% | 6^ | .  |
// | cut | copy | pst  | undo | redo |      |    |  1!  |  2@ | 3# | -_ |
//              | lock |  L4  |      |      | 0) | BSPC | DEL |
        display-name = "Number";
        bindings = <
   &kp ESCAPE      &kp LG(LEFT)  &kp UP        &kp LC(LEFT) &kp LC(RIGHT)      &none               &kp N7        &kp N8        &kp N9          &kp SLASH
   &hms LSHIFT TAB &kp LEFT      &kp DOWN      &kp RIGHT    &kp LG(RIGHT)      &kp EQUAL           &hm RGUI N4   &hm RALT N5   &hm RCTRL N6    &hms RSHIFT DOT
   &kp LG(X)       &kp LG(C)     &kp LG(V)     &kp LG(Z)    &kp LS(LG(Z))      &none               &kp N1        &kp N2        &kp N3          &kp MINUS
                                 &kp LG(LC(Q)) &mo 4        &none              &mt_tap RSHIFT N0   &kp BSPC      &kp DEL
        >;
    };

    sym_nav_mus_layer2 {
// -----------------------------------------------------------------------------------------
// | R Ptab | R Ntab | TAB  | volU | volU   |        |     |  `   |  [  |  ]  |    |
// | musPrv | Ptab   | Ntab | PLAY | musNxt |        |     | PIPE |  {  |  }  |    |
// | close  | Pwin   | Nwin | volD | volD   |        |     |  ~   |  \  |     |    |    
//                   |      |      |        |        | SPC | BSPC | DEL |
        display-name = "Nav/Music/Sym";
        bindings = <
   &kp LC(F11)        &kp LC(F12)             &kp TAB             &mt LGUI C_VOL_UP       &kp LC(LA(LS(U)))    &none     &kp GRAVE       &kp LBKT        &kp RBKT          &none
   &hms LSHIFT C_PREV &hm LCTRL LS(LC(TAB))   &hm LALT LC(TAB)    &hm LGUI C_PLAY_PAUSE   &kp C_NEXT           &none     &hm RGUI PIPE   &hm RALT LBRC   &hm RCTRL RBRC    &kp RSHIFT
   &kp LG(W)          &kp LS(LA(TAB))         &kp LA(TAB)         &kp C_VOL_DN            &kp LC(LA(LS(J)))    &none     &tildasgn       &kp BSLH        &none             &none
                                 &none        &none               &none                   &mt RSHIFT SPACE     &kp BSPC  &kp DEL
         >;
    };

    mouse_layer3 {
// -----------------------------------------------------------------------------------------
// | brghtD   | brghtU   |  UP      | rstrt R | add col  |        |      |       |    sUP    |        | SSall |
// | R indent | LEFT     | DOWN     | RIGHT   | run code |        |      | sLEFT |   sDOWN   | sRIGHT | SSsel |
// | R reflow | R source | R consol | R term  | adv code |        |      |       |           |        | SScpy |
//                       |          |         |          |        | Lclk | Rclk  | tog posit |
        display-name = "Mouse";
        bindings = <
   &kp LC(LA(LS(Q)))  &kp LC(LA(LS(W)))  &mmv MOVE_UP   &kp LG(LS(N0))  &kp LG(F7)    &none    &none          &msc SCRL_UP   &none           &kp LG(LS(N3))
   &hms LSHIFT LG(I)  &mmv MOVE_LEFT     &mmv MOVE_DOWN &mmv MOVE_RIGHT &kp LA(RET)   &none    &msc SCRL_LEFT &msc SCRL_DOWN &msc SCRL_RIGHT &kp LG(LS(N4))
   &kp LC(LS(SLASH))  &kp LC(N1)         &kp LC(N2)     &kp LA(LS(M))   &kp LG(RET)   &none    &none          &none          &none           &kp LG(LS(LC(N4)))
                                         &none          &none           &none         &mkp MB1 &mkp MB2       &tog 5
        >;
    };

    bluetooth_layer4 {
// -----------------------------------------------------------------------------------------
// |       |     |     |     |     |     |     |     |     |     |     |
// | BT1   | BT2 | BT3 | BT4 | BT5 |     |     |     |     |     |     |
// | BTCLR |     |     |     |     |     |     |     |     |     |     |
//               |     |     |     |     |     |     |     |
        display-name = "Bluetooth";
        bindings = <
   &none         &none         &none         &none         &none            &none  &none  &none  &none  &none
   &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4     &none  &none  &none  &none  &none
   &bt BT_CLR    &none         &none         &none         &none            &none  &none  &none  &none  &none
                               &none         &none         &none            &none  &none  &none
        >;
    };

    positron_base_layer5 {
// INTERCEPTOR LAYER: Transparent except for rerouting the left thumb to Layer 6
// -----------------------------------------------------------------------------------------
        display-name = "Positron Base";
        bindings = <
   &trans  &trans  &trans       &trans  &trans        &trans  &trans  &trans  &trans  &trans
   &trans  &trans  &trans       &trans  &trans        &trans  &trans  &trans  &trans  &trans
   &trans  &trans  &trans       &trans  &trans        &trans  &trans  &trans  &trans  &trans
                   &lft 6 DEL   &trans  &trans        &trans  &trans  &trans
        >;
    };

    positron_mouse_layer6 {
// ALTERNATE MOUSE LAYER: Contains the positron-specific shortcuts
// -----------------------------------------------------------------------------------------
// | brghtD   | brghtU   |  UP      | rstrt R |          |           |      |       |  sUP  |        | SSall |
// |          | LEFT     | DOWN     | RIGHT   | run code |           |      | sLEFT | sDOWN | sRIGHT | SSsel |
// |          |          | P consol | P term  | adv code |           |      |       |       |        | SScpy |
//                       |          |         |          |           | Lclk | Rclk  | togg5 |
        display-name = "Positron Mouse";
        bindings = <
   &kp LC(LA(LS(Q)))  &kp LC(LA(LS(W)))  &mmv MOVE_UP   &kp LG(LS(N0))  &none         &none     &none          &msc SCRL_UP   &none           &kp LG(LS(N3))
   &kp LSHIFT         &mmv MOVE_LEFT     &mmv MOVE_DOWN &mmv MOVE_RIGHT &kp LA(RET)   &none     &msc SCRL_LEFT &msc SCRL_DOWN &msc SCRL_RIGHT &kp LG(LS(N4))
   &none              &none              &pos_console   &kp LC(GRAVE)   &kp LG(RET)   &none     &none          &none          &none           &kp LG(LS(LC(N4)))
                                         &none          &none           &none         &mkp MB1  &mkp MB2       &tog 5
        >;
    };

    new_layer {
// -----------------------------------------------------------------------------------------
// |    |     |     |     |     |             |     |     |     |     |     |
// |    |     |     |     |     |             |     |     |     |     |     |
// |    |     |     |     |     |             |     |     |     |     |     |
//            |     |     |     |             |     |     |     |
        display-name = "New";
        bindings = <
   &none   &none   &none    &none    &none              &none    &none    &none    &none    &none
   &none   &none   &none    &none    &none              &none    &none    &none    &none    &none
   &none   &none   &none    &none    &none              &none    &none    &none    &none    &none
                   &none    &none    &none              &none    &none    &none
        >;
    };
};
};
